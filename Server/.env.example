# ============================================================
# PI Server Dashboard — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Authentication ---
# The backend stores only the SHA-256 hash of your token, never the raw value.
API_TOKEN_HASH=paste-the-sha256-hash-here

# --- Bot Configuration ---
# Comma-separated list of systemd service names (without .service suffix).
BOTS=bot1,bot2,bot3

# --- File Manager ---
FILE_MANAGER_ROOT=/home/pi

# --- Server ---
PORT=8080

# --- Bot Manager ---
# Directory where managed bot .service files are written.
SERVICE_DIR=/etc/systemd/system


# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=https://dash.eele14.dev
